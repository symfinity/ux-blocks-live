<div
    data-ui-role="tags-input"
    data-ui-fragment="blocks.live.tags-input"
    {% if disabled %}data-ui-state="disabled"{% endif %}
    {% if invalid %}data-ui-state="invalid"{% endif %}
    {{ attributes.without('data-controller').defaults({
        'data-controller': 'live symfony--ux-blocks-live--tags-input',
        'data-symfony--ux-blocks-live--tags-input-delimiter-value': delimiter,
    }) }}
>
    <div role="list" data-ui-role="tags-input-chips">
        {% for tag in tags %}
            {% set tagLabel = tag is iterable ? tag.label : tag %}
            <span
                role="listitem"
                data-ui-role="tags-input-chip"
                data-value="{{ tag is iterable ? (tag.value ?? tagLabel) : tagLabel }}"
            >
                {{ tagLabel }}
                {% if not disabled %}
                    <button
                        type="button"
                        aria-label="Remove {{ tagLabel }}"
                        data-action="live#action"
                        data-live-action-param="removeTag"
                        data-live-index-param="{{ loop.index0 }}"
                    >×</button>
                {% endif %}
            </span>
        {% endfor %}
    </div>
    <input
        type="text"
        {% if name %}name="{{ name }}_input"{% endif %}
        {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
        {% if disabled %}disabled{% endif %}
        {% if invalid %}aria-invalid="true"{% endif %}
        aria-label="{{ placeholder ?? 'Add tag' }}"
        data-ui-role="tags-input-field"
        data-model="draft"
        data-action="keydown.enter->live#action keydown->symfony--ux-blocks-live--tags-input#keydown input->symfony--ux-blocks-live--tags-input#input"
        data-live-action-param="addTag"
    />
    {% if name %}
        <input type="hidden" name="{{ name }}" value="{{ tags|json_encode }}" />
    {% endif %}
    {% block content %}{% endblock %}
</div>

{% set nodeId = node.id %}
{% set isExpanded = nodeId in expanded %}
{% set isSelected = selectable and selected == nodeId %}
{% set children = node.children ?? [] %}
{% set hasChildren = children|length > 0 %}
<li
    role="treeitem"
    data-ui-role="tree-view-item"
    data-node-id="{{ nodeId }}"
    {% if hasChildren %}aria-expanded="{{ isExpanded ? 'true' : 'false' }}"{% endif %}
    {% if isSelected %}aria-selected="true"{% elseif selectable %}aria-selected="false"{% endif %}
    {% if node.disabled|default(false) %}aria-disabled="true" data-ui-state="disabled"{% endif %}
    tabindex="{{ depth == 0 ? '0' : '-1' }}"
    data-symfony--ux-blocks-live--tree-view-target="item"
    data-action="click->symfony--ux-blocks-live--tree-view#activate keydown->symfony--ux-blocks-live--tree-view#keydown"
>
    <span data-ui-part="label">{{ node.label }}</span>
    {% if hasChildren %}
        <ul role="group" {% if not isExpanded %}hidden{% endif %} data-ui-role="tree-view-group">
            {% for child in children %}
                {% include '@UxBlocksLive/components/TreeView/_node.html.twig' with {
                    node: child,
                    expanded: expanded,
                    selected: selected,
                    selectable: selectable,
                    depth: depth + 1,
                } only %}
            {% endfor %}
        </ul>
    {% endif %}
</li>

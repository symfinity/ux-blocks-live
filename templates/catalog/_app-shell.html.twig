<section data-catalog-role="menubar">
    <h2>Menubar</h2>
    <twig:Menubar>
        <twig:Menubar:Trigger>File</twig:Menubar:Trigger>
        <twig:Menubar:Content>
            <twig:Menubar:Item>New tab</twig:Menubar:Item>
            <twig:Menubar:Item>New window</twig:Menubar:Item>
        </twig:Menubar:Content>
        <twig:Menubar:Trigger>Edit</twig:Menubar:Trigger>
        <twig:Menubar:Content>
            <twig:Menubar:Item>Undo</twig:Menubar:Item>
            <twig:Menubar:Item>Redo</twig:Menubar:Item>
        </twig:Menubar:Content>
        <twig:Menubar:Trigger>View</twig:Menubar:Trigger>
        <twig:Menubar:Content>
            <twig:Menubar:Item>Zoom in</twig:Menubar:Item>
            <twig:Menubar:Item>Zoom out</twig:Menubar:Item>
        </twig:Menubar:Content>
    </twig:Menubar>
</section>

<section data-catalog-role="navigation-menu">
    <h2>Navigation menu</h2>
    <twig:NavigationMenu>
        <twig:NavigationMenu:Trigger>Products</twig:NavigationMenu:Trigger>
        <twig:NavigationMenu:Content>
            <twig:NavigationMenu:Item href="#">Analytics</twig:NavigationMenu:Item>
            <twig:NavigationMenu:Item href="#">Automation</twig:NavigationMenu:Item>
        </twig:NavigationMenu:Content>
        <twig:NavigationMenu:Trigger>Company</twig:NavigationMenu:Trigger>
        <twig:NavigationMenu:Content>
            <twig:NavigationMenu:Item href="#">About</twig:NavigationMenu:Item>
            <twig:NavigationMenu:Item href="#">Careers</twig:NavigationMenu:Item>
        </twig:NavigationMenu:Content>
    </twig:NavigationMenu>
</section>

<section data-catalog-role="sidebar">
    <h2>Sidebar</h2>
    <twig:Sidebar side="left">
        <twig:Sidebar:Trigger data-ui-role="button">Open sidebar</twig:Sidebar:Trigger>
        <twig:Sidebar:Content>
            <twig:Sidebar:Header>
                <twig:Sidebar:Title>App navigation</twig:Sidebar:Title>
            </twig:Sidebar:Header>
            <nav>
                <a href="#">Dashboard</a>
                <a href="#">Settings</a>
            </nav>
            <twig:Sidebar:Close data-ui-role="button">Close</twig:Sidebar:Close>
        </twig:Sidebar:Content>
    </twig:Sidebar>
</section>

<section data-catalog-role="stacked-layout-interactive">
    <h2>Stacked layout</h2>
    <twig:StackedLayoutInteractive defaultPanel="overview">
        <twig:StackedLayoutInteractive:NavToggle data-ui-role="button">Menu</twig:StackedLayoutInteractive:NavToggle>
        <twig:StackedLayoutInteractive:Nav>
            <twig:StackedLayoutInteractive:NavItem panel="overview">Overview</twig:StackedLayoutInteractive:NavItem>
            <twig:StackedLayoutInteractive:NavItem panel="details">Details</twig:StackedLayoutInteractive:NavItem>
        </twig:StackedLayoutInteractive:Nav>
        <twig:StackedLayoutInteractive:Panel panel="overview">
            <h3>Overview panel</h3>
            <p>Catalyst-style stacked nav with panel switching.</p>
        </twig:StackedLayoutInteractive:Panel>
        <twig:StackedLayoutInteractive:Panel panel="details">
            <h3>Details panel</h3>
            <p>Secondary panel content.</p>
        </twig:StackedLayoutInteractive:Panel>
    </twig:StackedLayoutInteractive>
</section>
